# Frontend env example for LeaseFlow
# This file is for browser-safe variables only.
# Payment gateway and credit-check provider secrets must stay server-side.
# Configure those in Supabase Function secrets:
#   - PAYSTACK_SECRET_KEY (payment system)
#   - CREDIT_CHECK_PROVIDER and EXPERIAN_* (credit check system)

# Supabase project URL
VITE_SUPABASE_URL=https://qrzsomwdjofqicvpvvno.supabase.co
# Supabase browser anon key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFyenNvbXdkam9mcWljdnB2dm5vIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY1OTI3OTEsImV4cCI6MjA5MjE2ODc5MX0.C6eKUTHqY8SMYQ8g_YEX6qc_eGBYzR9u6-S_R-MkPao
# Redirect used by email confirmation and password recovery
VITE_SUPABASE_REDIRECT_URL=http://localhost:8080/signin

# App mode
VITE_ENVIRONMENT=production

# Background polling toggle (set true to re-enable)
VITE_ENABLE_BACKGROUND_POLLING=false

# Supabase storage bucket used for unit image uploads
VITE_SUPABASE_UNIT_IMAGES_BUCKET=unit-images

# Supabase storage bucket used for application document uploads
VITE_SUPABASE_DOCUMENTS_BUCKET=documents
